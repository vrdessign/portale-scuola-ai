# ══════════════════════════════════════════════════════
# Portale Scuola AI — Variabili d'ambiente
# Copia in .env e compila prima di avviare
# ══════════════════════════════════════════════════════

# ── LLM locale (vLLM) ──────────────────────────────────
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL=meta-llama/Llama-3.1-70B-Instruct
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3

# ── Embeddings ──────────────────────────────────────────
EMBED_MODEL=intfloat/multilingual-e5-large
EMBED_DEVICE=cuda
EMBED_BATCH_SIZE=64

# ── Qdrant ──────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ── PostgreSQL ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://portale:portale@localhost:5432/portale_scuola

# ── Auth ────────────────────────────────────────────────
SECRET_KEY=CAMBIA_QUESTA_STRINGA_CON_UNA_CASUALE_LUNGA_64_CARATTERI
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── App ─────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=5000
APP_DEBUG=false
